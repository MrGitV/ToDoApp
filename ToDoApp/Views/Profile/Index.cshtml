@model ToDoApp.Models.Employee
@{
    ViewData["Title"] = "My Profile Settings";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0"><i class="bi bi-person-gear"></i> Profile Settings</h4>
                @if (User.IsInRole(ToDoApp.Models.UserRole.Admin))
                {
                    <span class="badge bg-danger fs-6"><i class="bi bi-shield-lock"></i> System Admin</span>
                }
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Update" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="text-center mb-4">
                        <img src="@Url.Action("GetAvatar", "Employees", new { id = Model.Id })"
                             class="rounded-circle img-thumbnail shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Avatar" id="avatarPreview" />
                        <div class="mt-3">
                            <label for="avatarFile" class="btn btn-sm btn-outline-primary"><i class="bi bi-camera"></i> Change Avatar</label>
                            <input type="file" name="avatarFile" id="avatarFile" class="d-none" accept="image/*" />
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-bold">First Name</label>
                            <input asp-for="FirstName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-bold">Last Name</label>
                            <input asp-for="LastName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-bold">Date of Birth</label>
                            <input asp-for="DateOfBirth" type="date" class="form-control" required value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Username (Read-only)</label>
                            <input value="@Model.Username" class="form-control text-muted bg-light" readonly />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Specialty (Read-only)</label>
                            <input value="@Model.Specialty" class="form-control text-muted bg-light" readonly />
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex justify-content-between">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left-circle"></i> Cancel</a>
                        <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const avatarFileInput = document.getElementById('avatarFile');
        if (avatarFileInput) {
            avatarFileInput.addEventListener('change', function(e) {
                if (e.target.files && e.target.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        document.getElementById('avatarPreview').src = e.target.result;
                    }
                    reader.readAsDataURL(e.target.files[0]);
                }
            });
        }
    </script>
}