@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Views/Shared/_LayoutUnauthenticated.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <h1 class="display-1 text-danger fw-bold"><i class="bi bi-shield-lock-fill"></i> 403</h1>
        <h2 class="mb-4">Access Denied</h2>
        <p class="lead text-muted mb-5">You do not have permission to view this resource.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-house-door"></i> Return to Dashboard
        </a>
    </div>
</div>