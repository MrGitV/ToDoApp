@model ToDoApp.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Welcome, Admin!</h1>
    <p class="lead text-muted">System-wide statistics and management overview.</p>
</div>

<div class="row text-center mb-5">
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-white bg-primary h-100 shadow">
            <div class="card-header border-0 pb-0">
                <h5 class="card-title"><i class="bi bi-people-fill"></i> Total Employees</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-3 fw-bold">@Model.TotalEmployees</h2>
                <a asp-controller="Employees" asp-action="Index" class="btn btn-outline-light mt-3">Manage Employees</a>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-white bg-success h-100 shadow">
            <div class="card-header border-0 pb-0">
                <h5 class="card-title"><i class="bi bi-card-checklist"></i> Total Tasks</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-3 fw-bold">@Model.TotalTasks</h2>
                <a asp-controller="Tasks" asp-action="Index" class="btn btn-outline-light mt-3">View All Tasks</a>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-dark bg-warning h-100 shadow">
            <div class="card-header border-0 pb-0">
                <h5 class="card-title"><i class="bi bi-exclamation-triangle-fill"></i> Pending Tasks</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-3 fw-bold">@Model.PendingTasks</h2>
                <a asp-controller="Tasks" asp-action="Index" asp-route-isCompleted="false" class="btn btn-outline-dark mt-3">View Pending</a>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-white bg-danger h-100 shadow">
            <div class="card-header border-0 pb-0">
                <h5 class="card-title"><i class="bi bi-x-octagon-fill"></i> Failed Tasks</h5>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-3 fw-bold">@Model.FailedTasks</h2>
                <a asp-controller="Tasks" asp-action="Index" class="btn btn-outline-light mt-3">View Failed</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-pie-chart-fill text-primary"></i> Task Completion Analytics</h5>
            </div>
            <div class="card-body d-flex justify-content-center">
                <div style="width: 300px; height: 300px;">
                    <canvas id="tasksChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        var ctx = document.getElementById('tasksChart').getContext('2d');
            
        var totalTasks = parseInt('@Model.TotalTasks', 10) || 0;
        var pendingTasks = parseInt('@Model.PendingTasks', 10) || 0;
        var failedTasks = parseInt('@Model.FailedTasks', 10) || 0;
        var completedTasks = totalTasks - pendingTasks - failedTasks;

        if(totalTasks === 0) {
        document.getElementById('tasksChart').style.display = 'none';
        ctx.canvas.parentNode.innerHTML = '<p class="text-muted mt-5 text-center">No tasks available to display.</p>';
        return;
        }

        var tasksChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: ['Completed', 'Pending', 'Failed'],
        datasets: [{
        data: [completedTasks, pendingTasks, failedTasks],
        backgroundColor: [
        'rgba(25, 135, 84, 0.8)',
        'rgba(255, 193, 7, 0.8)',
        'rgba(220, 53, 69, 0.8)'
        ],
        borderColor: [
        'rgba(25, 135, 84, 1)',
        'rgba(255, 193, 7, 1)',
        'rgba(220, 53, 69, 1)'
        ],
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: {
        position: 'bottom',
        }
        }
        }
        });
        });
    </script>
}