@model ToDoApp.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Welcome, @User.Identity?.Name!</h1>
    <p class="lead text-muted">Here is a summary of your assigned tasks.</p>
</div>

<div class="row text-center mb-5">
    <!-- Total Tasks Card -->
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-white bg-primary h-100 shadow">
            <div class="card-header border-0 pb-0"><h5 class="card-title">Total Tasks</h5></div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-4 fw-bold">@Model.TotalTasks</h2>
                <a asp-controller="Tasks" asp-action="Index" class="btn btn-outline-light btn-sm mt-2">View All My Tasks</a>
            </div>
        </div>
    </div>

    <!-- Completed Tasks Card -->
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-white bg-success h-100 shadow">
            <div class="card-header border-0 pb-0"><h5 class="card-title">Completed</h5></div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-4 fw-bold">@(Model.TotalTasks - Model.PendingTasks - Model.FailedTasks)</h2>
                <a asp-controller="Tasks" asp-action="Index" asp-route-isCompleted="true" class="btn btn-outline-light btn-sm mt-2">View Finished</a>
            </div>
        </div>
    </div>

    <!-- Pending Tasks Card -->
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-dark bg-warning h-100 shadow">
            <div class="card-header border-0 pb-0"><h5 class="card-title">Pending</h5></div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-4 fw-bold">@Model.PendingTasks</h2>
                <a asp-controller="Tasks" asp-action="Index" asp-route-isCompleted="false" class="btn btn-outline-dark btn-sm mt-2">View Active</a>
            </div>
        </div>
    </div>

    <!-- Failed Tasks Card -->
    <div class="col-lg-3 col-md-6 mb-4">
        <div class="card text-white bg-danger h-100 shadow">
            <div class="card-header border-0 pb-0"><h5 class="card-title">Failed / Overdue</h5></div>
            <div class="card-body d-flex flex-column justify-content-center">
                <h2 class="display-4 fw-bold">@Model.FailedTasks</h2>
                <a asp-controller="Tasks" asp-action="Index" class="btn btn-outline-light btn-sm mt-2">Check Deadlines</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-pie-chart-fill text-primary"></i> My Task Progress</h5>
            </div>
            <div class="card-body d-flex justify-content-center">
                <div style="width: 300px; height: 300px;">
                    <canvas id="tasksChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        var ctx = document.getElementById('tasksChart').getContext('2d')
        var totalTasks = parseInt('@Model.TotalTasks', 10) || 0;
        var pending = parseInt('@Model.PendingTasks', 10) || 0;
        var failed = parseInt('@Model.FailedTasks', 10) || 0;
        var completed = totalTasks - pending - failed;

        if(totalTasks === 0) {
        document.getElementById('tasksChart').style.display = 'none';
        ctx.canvas.parentNode.innerHTML = '<p class="text-muted mt-5 text-center">No tasks assigned to you yet.</p>';
        return;
        }

        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: ['Completed', 'Pending', 'Failed'],
        datasets: [{
        data: [completed, pending, failed],
        backgroundColor: ['#198754', '#ffc107', '#dc3545'],
        borderColor: ['#198754', '#ffc107', '#dc3545'],
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: { position: 'bottom' }
        }
        }
        });
        });
    </script>
}